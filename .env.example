# LLM (OpenRouter) — optional server demo key; users can BYOK in chat UI
OPENROUTER_API_KEY=

# =============================================================================
# Walrus Memory — MAINNET (operator setup, one-time)
# https://memory.walrus.xyz/dashboard
#
# 1. Connect wallet (Sui mainnet)
# 2. Create MemWalAccount (first visit)
# 3. Create DELEGATE key (NOT owner key) → copy private key once
# 4. Copy Account object ID
#
# Users only connect wallet in the app — memory namespace: special-one-{address}
# Full guide: docs/MEMWAL_SETUP.md
# =============================================================================
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
# Optional: show MemWalAccount explorer link in UI (safe to expose)
NEXT_PUBLIC_MEMWAL_ACCOUNT_ID=

# Football API (optional — manual results still work)
# Prefer SportMonks World Cup 2026 (league 732, season 26618)
SPORTMONKS_API_TOKEN=
# Fallback if SportMonks token unset
API_FOOTBALL_KEY=

# Auth message domain
AUTH_MESSAGE_DOMAIN=mr-toxic-special-one
NEXT_PUBLIC_AUTH_MESSAGE_DOMAIN=mr-toxic-special-one

# Sui network for wallet
NEXT_PUBLIC_SUI_NETWORK=mainnet
