# =============================================================================
# Mr. Toxic Special One — environment template
# Copy to .env.local for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables.
# Never commit .env.local or real API keys.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (optional server-side demo keys — users can BYOK in Settings UI)
# At least one provider key OR user BYOK required for chat to work.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Walrus Memory / MemWal — MAINNET (operator, server-only secrets)
# Setup: https://memory.walrus.xyz/dashboard
# Guide: docs/MEMWAL_SETUP.md
# Verify locally: npm run memwal:verify
#
# Required for live cross-session memory demo on production.
# Users only connect Sui wallet — namespace: mr-toxic-special-one-{address}
# -----------------------------------------------------------------------------
MEMWAL_PRIVATE_KEY=
# Alias accepted by the app (same value as delegate key):
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
MEMWAL_RELAYER_URL=https://relayer.memory.walrus.xyz
# Optional: show MemWalAccount explorer link in UI (safe to expose)
NEXT_PUBLIC_MEMWAL_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Football data (optional)
# Without API_FOOTBALL_KEY, demo fixtures from data/wc2026-fixtures.json are used.
# -----------------------------------------------------------------------------
API_FOOTBALL_KEY=

# -----------------------------------------------------------------------------
# Wallet auth (sign-in message domain — must match on client and server)
# Production: set to your Vercel hostname, e.g. special-one-agent.vercel.app
# -----------------------------------------------------------------------------
AUTH_MESSAGE_DOMAIN=mr-toxic-special-one
NEXT_PUBLIC_AUTH_MESSAGE_DOMAIN=mr-toxic-special-one

# -----------------------------------------------------------------------------
# Sui wallet network (client)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUI_NETWORK=mainnet

# -----------------------------------------------------------------------------
# Vercel / production notes (auto-injected by Vercel — do not set manually)
# VERCEL_URL, VERCEL_ENV, NODE_ENV
#
# Serverless timeouts:
#   vercel.json sets maxDuration: 60 on /api/chat and /api/memory/*
#   Requires Vercel Pro for full 60s; Hobby plan caps at ~10s per function.
# -----------------------------------------------------------------------------
